---
import { footer, site } from "../lib/content";
---
<footer class="mx-auto max-w-[var(--container-frame)] px-[var(--page-pad)] py-[clamp(3rem,7vw,4rem)] mt-[var(--spacing-section)] border-t border-[var(--color-border-faint)]">
  <div class="flex items-center gap-3 mb-6" aria-hidden="true">
    <img src="/cairn-mark.svg" width="34" height="28" alt="" />
    <span class="font-sans font-semibold tracking-[-0.025em] text-[15px]">agentcairn</span>
  </div>
  <p class="font-serif text-[14px] text-[var(--color-ink-muted)] max-w-[var(--container-prose)] mb-6">
    <span class="font-mono text-[var(--color-ink)]">cairn</span>&nbsp;<span class="font-mono text-[12px] text-[var(--color-ink-faint)]">/kɛən/ · noun</span> — {footer.definition}
  </p>
  <nav aria-label="Guides" class="font-mono text-[12px] text-[var(--color-ink-faint)] flex flex-wrap gap-x-6 gap-y-2 mb-6">
    <span class="text-[var(--color-ink)]">Guides</span>
    {footer.guides.map((g) => (
      <a href={g.href} class="hover:text-[var(--color-ink)]">{g.label}</a>
    ))}
  </nav>
  <div class="font-mono text-[12px] text-[var(--color-ink-faint)] flex flex-wrap gap-x-6 gap-y-2">
    <span>{footer.copyright}</span>
    <a href={`${site.repo}/blob/main/LICENSE`} class="hover:text-[var(--color-ink)]">{footer.license}</a>
    <a href={site.repo} class="hover:text-[var(--color-ink)]">GitHub</a>
    <span class="text-[var(--color-ink)]">uvx agentcairn</span>
  </div>
</footer>
