---
import Section from "./Section.astro";
import Prose from "./Prose.astro";
import CommandBox from "./CommandBox.astro";

const command = [
  "uvx --from agentcairn cairn import claude-memory          # preview",
  "uvx --from agentcairn cairn import claude-memory --apply  # import + index",
].join("\n");
---
<Section id="claude-memory" eyebrow="New in v0.25" eyebrowHeading={false}>
  <h2 class="font-serif text-[30px] leading-tight mb-4">
    Claude learned it once. Bring it to every supported agent.
  </h2>
  <Prose>
    <p>
      Import Claude Code&rsquo;s auto-memory into the shared Markdown vault without
      changing Claude&rsquo;s source files. Preview the current repository first;
      apply only when the plan looks right.
    </p>
  </Prose>
  <div class="mt-5">
    <CommandBox command={command} />
  </div>
  <p class="mt-4 font-serif text-[16px]">
    <a href="/claude-code-memory/" class="underline">See exactly what is imported and how history is preserved</a>
  </p>
</Section>
