---
import Section from "./Section.astro";
import Prose from "./Prose.astro";
import { howItWorks } from "../lib/content";

const steps = [
  { n: "01", label: "Capture", title: "Agent sessions", meta: "hooks + sweep" },
  { n: "02", label: "Keep", title: "Markdown vault", meta: "redacted + inspectable", strong: true },
  { n: "03", label: "Index", title: "DuckDB cache", meta: "hybrid + rebuildable" },
  { n: "04", label: "Recall", title: "MCP context", meta: "cited + project-aware", dark: true },
];
---
<Section id="how" eyebrow="How it works">
  <Prose><p>{howItWorks.body}</p></Prose>
  <figure class="how-flow mt-10" aria-labelledby="how-flow-caption">
    <figcaption id="how-flow-caption" class="sr-only">
      Agent sessions are captured into a canonical Markdown vault, indexed in a rebuildable DuckDB cache, and returned as cited MCP context.
    </figcaption>
    {steps.map((step, index) => (
      <>
        <div class:list={["how-step", step.strong && "how-step--strong", step.dark && "how-step--dark"]}>
          <div class="how-step__top"><span>{step.n}</span><span>{step.label}</span></div>
          <p>{step.title}</p>
          <small>{step.meta}</small>
        </div>
        {index < steps.length - 1 && <div class="how-arrow" aria-hidden="true"><i></i></div>}
      </>
    ))}
  </figure>
</Section>
