---
import { nav, navGuides } from "../lib/content";

const normalizedPath = (href: string) => href.replace(/\/+$/, "");
const github = navGuides.find((item) => item.label === "GitHub" || item.href.includes("github.com"));
const guides = navGuides.filter((item) => item !== github && normalizedPath(item.href) !== "");
---
<nav aria-label="Primary" class="site-nav mx-auto flex max-w-[var(--container-frame)] items-center justify-between gap-6 px-[var(--page-pad)] py-5 border-b border-[var(--color-border-faint)]">
  <a href="/" class="brand-link nav-hit-target font-sans font-semibold tracking-[-0.025em] text-[16px] shrink-0">
    <img src="/cairn-mark.svg" width="42" height="34" alt="" aria-hidden="true" />
    <span>agentcairn</span>
  </a>

  <div class="desktop-nav hidden lg:flex font-mono text-[13px] text-[var(--color-ink-muted)] items-center justify-end gap-x-5">
    {nav.map((n) => <a href={n.href} class="nav-hit-target hover:text-[var(--color-ink)]">{n.label}</a>)}
    {guides.length > 0 && (
      <details class="desktop-more">
        <summary class="nav-hit-target">Guides</summary>
        <div class="desktop-more__panel">
          {guides.map((n) => <a href={n.href}>{n.label}</a>)}
        </div>
      </details>
    )}
    {github && <a href={github.href} class="nav-hit-target hover:text-[var(--color-ink)]">{github.label}</a>}
  </div>

  <details class="mobile-menu lg:hidden">
    <summary class="mobile-menu__trigger font-mono text-[12px] text-[var(--color-ink-muted)]">
      <span>Menu</span>
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <path d="M2 5l5 5 5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </summary>
    <div class="mobile-menu__panel">
      <p class="mobile-menu__label">Product</p>
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      <div class="mobile-menu__rule" aria-hidden="true"></div>
      <p class="mobile-menu__label">Guides</p>
      {guides.map((n) => <a href={n.href}>{n.label}</a>)}
      {github && <a href={github.href}>{github.label}</a>}
    </div>
  </details>
</nav>

<style>
  .nav-hit-target {
    display: inline-flex;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }
</style>

<script>
  document.querySelectorAll<HTMLDetailsElement>(".mobile-menu, .desktop-more").forEach((menu) => {
    menu.querySelectorAll("a").forEach((link) =>
      link.addEventListener("click", () => {
        menu.removeAttribute("open");

        // A same-page hash link would otherwise leave keyboard focus inside
        // content that just became hidden when the disclosure closed.
        const targetUrl = new URL(link.href, window.location.href);
        const isSamePage = targetUrl.origin === window.location.origin
          && targetUrl.pathname === window.location.pathname
          && targetUrl.hash.length > 1;
        if (!isSamePage) return;

        window.requestAnimationFrame(() => {
          const target = document.getElementById(decodeURIComponent(targetUrl.hash.slice(1)));
          if (!target) return;
          target.setAttribute("tabindex", "-1");
          target.focus({ preventScroll: true });
          target.addEventListener("blur", () => target.removeAttribute("tabindex"), { once: true });
        });
      }),
    );
    menu.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        menu.removeAttribute("open");
        menu.querySelector<HTMLElement>("summary")?.focus();
      }
    });
  });
</script>
