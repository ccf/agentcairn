---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import CommandBox from "../components/CommandBox.astro";
// Default CTA is host-neutral (`--all` configures every detected agent). A page
// may override `cta` if it's specific to one host.
const { title, description, faq, cta = "cairn install --all" } = Astro.props;
---
<Base title={title} description={description} faq={faq}>
  <Nav />
  <main id="main">
    <p class="px-6 pt-6"><a href="/" class="text-[var(--color-ink-muted)] hover:underline">← agentcairn</a></p>
    <slot />
    <Section id="cta" eyebrow="Get started">
      <p class="font-serif text-[16px] mb-3">Install agentcairn into your agent in one command:</p>
      <CommandBox command={cta} />
      <p class="mt-4 font-serif text-[16px]"><a href="https://github.com/ccf/agentcairn" class="underline">GitHub</a> · <a href="/#quickstart" class="underline">Full quickstart</a></p>
    </Section>
  </main>
  <Footer />
</Base>
