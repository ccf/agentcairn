{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command",
        "command": "/bin/sh \"${PLUGIN_ROOT}/scripts/session-start.sh\"", "timeout": 20 } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command",
        "command": "/bin/sh \"${PLUGIN_ROOT}/scripts/session-end.sh\"", "timeout": 120 } ] }
    ]
  }
}
